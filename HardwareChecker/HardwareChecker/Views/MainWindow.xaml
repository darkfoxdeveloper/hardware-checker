<Window x:Class="HardwareChecker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hardware Checker"
        Width="1440"
        Height="900"
        MinWidth="980"
        MinHeight="680"
        Icon="/Resources/app-icon.png"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="292" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="38"
                            Height="38"
                            CornerRadius="8"
                            Background="#E8F1FF"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1">
                        <Image Source="/Resources/app-icon.png"
                               Width="30"
                               Height="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Hardware Checker"
                                   FontSize="23"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Diagnostico local de Windows"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,22,0,16"
                        Padding="16"
                        CornerRadius="8"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Estado general"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <Border Grid.Column="1"
                                    Padding="9,4"
                                    CornerRadius="12"
                                    Background="{Binding OverallStatus, Converter={StaticResource StatusToBrushConverter}}">
                                <TextBlock Text="{Binding OverallStatusText}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding HealthScore, StringFormat={}{0}/100}"
                                   Margin="0,14,0,0"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding AlertSummaryText}"
                                   Margin="0,2,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding HealthTrendText}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding LastScanText}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2">
                    <Button Command="{Binding StartDiagnosticCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Run" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <TextBlock Text="Iniciar diagnostico" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportReportCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="EXP" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <TextBlock Text="Exportar informe" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CopyReportCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CPY" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <TextBlock Text="Copiar informe" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleLiveMonitorCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LIVE" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding LiveMonitorText}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,24,0,0">
                    <TextBlock Text="Progreso"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="14" />
                    <Grid Margin="0,10,0,0">
                        <ProgressBar Height="10"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding Progress, Mode=OneWay}" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0}%}"
                                   HorizontalAlignment="Right"
                                   Margin="0,24,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                </StackPanel>

                <TextBlock Grid.Row="4"
                           Text="Los sensores dependen de WMI, drivers y permisos del equipo."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Resumen del equipo"
                               FontSize="27"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="CPU, memoria, discos, GPU, bateria, red y dispositivos"
                               Margin="0,5,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentReport.MachineName, TargetNullValue=Equipo pendiente}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ListBox ItemsSource="{Binding Summaries}"
                         SelectedItem="{Binding SelectedSummary, Mode=TwoWay}"
                         Style="{StaticResource SummaryListBoxStyle}"
                         ItemContainerStyle="{StaticResource SummaryItemContainerStyle}"
                         Margin="0,0,0,6">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="214"
                                    MinHeight="130"
                                    Style="{StaticResource MetricCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="38"
                                            Height="30"
                                            CornerRadius="7"
                                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}">
                                        <TextBlock Text="{Binding Icon}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   FontSize="11" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding PrimaryValue}"
                                               FontSize="23"
                                               FontWeight="SemiBold"
                                               Margin="0,14,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding SecondaryValue}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedSummary.Name, TargetNullValue=Detalles}"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding SelectedSummary.Description}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Width="12"
                                        Height="12"
                                        CornerRadius="6"
                                        Background="{Binding SelectedSummary.Status, Converter={StaticResource StatusToBrushConverter}}"
                                        VerticalAlignment="Top" />
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          Margin="0,16,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedDetails}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Value}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Note}"
                                                                   Margin="0,4,0,0"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </StackPanel>
                                                    <Ellipse Grid.Column="2"
                                                             Width="10"
                                                             Height="10"
                                                             Margin="12,4,0,0"
                                                             Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                                             VerticalAlignment="Top" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                        <TabControl>
                            <TabItem Header="Alertas">
                                <Grid Margin="0,14,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ComboBox ItemsSource="{Binding AlertFilters}"
                                              SelectedItem="{Binding SelectedAlertFilter, Mode=TwoWay}"
                                              Margin="0,0,0,10"
                                              MinHeight="32" />

                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding FilteredAlerts}"
                                             SelectedItem="{Binding SelectedAlert, Mode=TwoWay}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="32"
                                                                Height="26"
                                                                CornerRadius="6"
                                                                Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                                                VerticalAlignment="Top">
                                                            <TextBlock Text="!"
                                                                       Foreground="White"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Category}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Message}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding Recommendation}"
                                                                       Margin="0,6,0,0"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextPrimaryBrush}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Recommendation}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Text="Sin alertas activas."
                                               Grid.Row="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FilteredAlerts.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Grid.Row="2"
                                            Command="{Binding ResolveSelectedAlertCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,12,0,0">
                                        <TextBlock Text="{Binding SelectedAlertActionText}" />
                                    </Button>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Informe">
                                <TextBox Text="{Binding DetailsText, Mode=OneWay}"
                                         Margin="0,14,0,0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0"
                                         Background="{StaticResource SurfaceBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontFamily="Consolas"
                                         Padding="12" />
                            </TabItem>

                            <TabItem Header="Historial">
                                <Grid Margin="0,14,0,0">
                                    <ListBox ItemsSource="{Binding DiagnosticHistory}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:g}}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding DeltaText}"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding HealthScore, StringFormat={}{0}/100}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding AlertCount, StringFormat={}{0} alertas}"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Text="Ejecuta al menos un diagnostico para crear historial."
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DiagnosticHistory.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
